# Copy to .env and fill with your real values
# DO NOT commit .env

# Baseline inference.py (OpenAI-compatible endpoint)
# Default: Groq (free, fast)
OPENAI_API_KEY=gsk_your_groq_key_here
API_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile

# HuggingFace (for pushing to Spaces + Inference API)
HF_TOKEN=hf_your_hf_token_here

# Weights & Biases (for training)
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=smb-ad-manager

# Task config
TASK_ID=easy

# HF Space URL (set after first deploy)
# Format: https://<hf-username-lowercase>-<space-name>.hf.space
SPACE_URL=https://falgunisharma-smb-ad-manager.hf.space
